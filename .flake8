[flake8]
# Aligned with OCA l10n-argentina-16.0/.flake8 (canonical OCA flake8 config).
# max-line-length=88 matches black.
# B950 (bugbear "line too long > max + 10%") = effectively cap at 97 chars;
# enforced together with B9 since TD-005 resolution.
max-line-length = 88
max-complexity = 16
# B = bugbear; B9 = opinionated bugbear checks (B017/B907/B950, etc.) — both
# selected since TD-005 resolution (2026-05-28).
select = C,E,F,W,B,B9
# E203: whitespace before ':' (black behaviour)
# E501: line length (88 black-enforced; B950 takes over the >88+10% check)
# W503: line break before binary operator (black behaviour)
ignore = E203,E501,W503
per-file-ignores =
    __init__.py:F401
    __manifest__.py:B018
