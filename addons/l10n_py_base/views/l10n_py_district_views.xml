<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="l10n_py_district_view_list" model="ir.ui.view">
        <field name="name">l10n_py.district.list</field>
        <field name="model">l10n_py.district</field>
        <field name="arch" type="xml">
            <list string="Distritos">
                <field name="code"/>
                <field name="name"/>
                <field name="state_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="l10n_py_district_view_search" model="ir.ui.view">
        <field name="name">l10n_py.district.search</field>
        <field name="model">l10n_py.district</field>
        <field name="arch" type="xml">
            <search string="Distritos">
                <field name="name"/>
                <field name="code"/>
                <field name="state_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Departamento" context="{'group_by': 'state_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="l10n_py_district_view_form" model="ir.ui.view">
        <field name="name">l10n_py.district.form</field>
        <field name="model">l10n_py.district</field>
        <field name="arch" type="xml">
            <form string="Distrito">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="state_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_l10n_py_district" model="ir.actions.act_window">
        <field name="name">Distritos</field>
        <field name="res_model">l10n_py.district</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
